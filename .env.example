# Damebooru Docker Configuration
# Copy this file to .env and adjust as needed.

# --- Authentication ---
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# --- Ports ---
SERVER_PORT=6666
CLIENT_PORT=8080

# --- Media ---
# Path on the host machine to your media library (images/videos).
MEDIA_PATH=./media

# --- AI Tagging ---
# Also start compose with: docker compose --profile ai up
AI_TAGGING_ENABLED=false
AI_TAGGING_BASE_URL=http://ai-tagging:8000
